model Venue {
  id          String   @id @default(uuid())
  name        String
  address     String
  district    String
  city        String
  type        String
  pricePerHour Int
  images      String[]
  ownerId     String
  isActive    Boolean  @default(false)

  owner       User     @relation(fields: [ownerId], references: [id])
  slots       VenueSlot[]
  bookings    Booking[]   @relation("VenueBookings")   // thêm tên relation

  @@map("venues")
}

model Booking {
  id          String        @id @default(uuid())
  userId      String
  venueSlotId String        @unique
  status      BookingStatus @default(PENDING)
  totalPrice  Int
  cancelledAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id])
  slot        VenueSlot     @relation(fields: [venueSlotId], references: [id])
  venue       Venue         @relation("VenueBookings", fields: [venueId], references: [id])  // thêm dòng này

  venueId     String        // thêm trường này để link trực tiếp với Venue

  @@map("bookings")
}