// ============================================================
// DatSanVN — Prisma Schema (v1.2)
// Nền tảng đặt sân thể thao trực tuyến
// ============================================================
// Business Rules:
// - Booking states: PENDING → CONFIRMED → COMPLETED / CANCELLED
// - Slot lock 5 phút bằng Redis TTL (xử lý ở application layer)
// - OWNER phải được ADMIN duyệt (VenueOwner.status = APPROVED)
// - Chủ sân chỉ CANCEL trước 24h
// - Refund: 100% trước 12h, 50% trước 6h, 0% trong 6h cuối
// ============================================================
// v1.2 Changes:
// - Prisma 7 compatible (no url in datasource)
// - Added FieldSize enum
// - Unified enum names (UserRole, VenueOwnerStatus)
// - Decimal for price fields
// - Default role = PLAYER
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  PLAYER
  OWNER
  ADMIN
}

enum VenueOwnerStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SportType {
  FOOTBALL
  BADMINTON
  TENNIS
  BASKETBALL
  VOLLEYBALL
  TABLE_TENNIS
  PICKLEBALL
}

enum FieldSize {
  FIELD_5
  FIELD_7
  FIELD_11
  OTHER
}

enum SlotStatus {
  AVAILABLE
  LOCKED // Redis TTL 5 phút quản lý auto-release
  BOOKED
}

enum BookingStatus {
  PENDING // Chờ thanh toán / confirm
  CONFIRMED // Đã thanh toán + slot locked
  COMPLETED // Hoàn thành trận đấu
  CANCELLED // Đã hủy
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED_FULL
  REFUNDED_HALF
  FAILED
}

enum PaymentMethod {
  MOMO
  VNPAY
  BANK_TRANSFER
  CASH
}

// ============================================================
// MODELS
// ============================================================

model User {
  id        String   @id @default(uuid())
  clerkId   String?  @unique @map("clerk_id")
  email     String   @unique
  fullName  String   @map("full_name")
  phone     String?
  avatarUrl String?  @map("avatar_url")
  role      UserRole @default(PLAYER)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ownerships VenueOwner[]
  bookings   Booking[]
  payments   Payment[]
  reviews    Review[]

  @@map("users")
}

model Venue {
  id          String    @id @default(uuid())
  name        String
  description String?
  address     String
  district    String
  city        String
  latitude    Float?
  longitude   Float?
  images      String[]
  amenities   String[]
  isActive    Boolean   @default(false) @map("is_active") // ADMIN duyệt sân
  rating      Float     @default(0.0)
  reviewCount Int       @default(0) @map("review_count")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  owners   VenueOwner[]
  fields   Field[]
  bookings Booking[]
  reviews  Review[]

  @@index([city, district])
  @@index([isActive])
  @@map("venues")
}

model Field {
  id        String    @id @default(uuid())
  venueId   String    @map("venue_id")
  name      String // "Sân 1", "Sân 5A", "Court A"
  sportType SportType @map("sport_type")
  size      FieldSize @default(FIELD_7)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  venue Venue       @relation(fields: [venueId], references: [id], onDelete: Cascade)
  slots VenueSlot[]

  @@index([venueId])
  @@index([sportType])
  @@map("fields")
}

model VenueOwner {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  venueId   String           @map("venue_id")
  status    VenueOwnerStatus @default(PENDING)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([userId, venueId])
  @@index([status])
  @@map("venue_owners")
}

model VenueSlot {
  id           String     @id @default(uuid())
  fieldId      String     @map("field_id")
  date         DateTime   @db.Date
  startTime    DateTime   @map("start_time") @db.Time(0)
  endTime      DateTime   @map("end_time") @db.Time(0)
  pricePerSlot Decimal    @map("price_per_slot") // changed to Decimal
  status       SlotStatus @default(AVAILABLE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  field        Field         @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  bookingSlots BookingSlot[]

  @@index([fieldId, date])
  @@index([fieldId, date, startTime])
  @@index([fieldId, date, status])
  @@index([status])
  @@map("venue_slots")
}

model Booking {
  id           String        @id @default(uuid())
  userId       String        @map("user_id")
  venueId      String        @map("venue_id")
  status       BookingStatus @default(PENDING)
  totalPrice   Decimal       @map("total_price") // changed to Decimal
  note         String?
  cancelReason String?       @map("cancel_reason")
  cancelledAt  DateTime?     @map("cancelled_at")
  cancelledBy  String?       @map("cancelled_by")
  expiresAt    DateTime?     @map("expires_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id])
  venue        Venue         @relation(fields: [venueId], references: [id])
  bookingSlots BookingSlot[]
  payment      Payment?
  review       Review?

  @@index([userId, status])
  @@index([venueId, status])
  @@index([createdAt])
  @@map("bookings")
}

model BookingSlot {
  id          String @id @default(uuid())
  bookingId   String @map("booking_id")
  venueSlotId String @map("venue_slot_id")

  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  venueSlot VenueSlot @relation(fields: [venueSlotId], references: [id])

  @@unique([bookingId, venueSlotId])
  @@index([venueSlotId])
  @@map("booking_slots")
}

model Payment {
  id            String        @id @default(uuid())
  bookingId     String        @unique @map("booking_id")
  userId        String        @map("user_id")
  amount        Decimal       @map("amount")
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?       @map("transaction_id")
  refundAmount  Decimal?      @map("refund_amount")
  refundedAt    DateTime?     @map("refunded_at")
  paidAt        DateTime?     @map("paid_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("payments")
}

model Review {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  venueId   String   @map("venue_id")
  bookingId String   @unique @map("booking_id")
  rating    Int // 1-5
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id])
  venue   Venue   @relation(fields: [venueId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([venueId])
  @@index([rating])
  @@map("reviews")
}
