# ============================================================
# DatSanVN — Environment Variables
# Copy to .env và điền giá trị thật
# ============================================================

# Database (Neon PostgreSQL)
# DATABASE_URL: Pooler endpoint (cho runtime queries)
DATABASE_URL="postgresql://neondb_owner:PASSWORD@ENDPOINT-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# DIRECT_URL: Non-pooler endpoint (cho migrations)
DIRECT_URL="postgresql://neondb_owner:PASSWORD@ENDPOINT.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Redis (cho slot locking 5 phút — sẽ dùng ở Mission sau)
REDIS_URL="redis://localhost:6379"

# Clerk Authentication
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"
CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxx"

# Server
PORT=3001
NODE_ENV="development"
